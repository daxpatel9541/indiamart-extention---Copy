{
  "manifest_version": 3,
  "name": "IndiaMART Lead Extractor",
  "version": "2.0.0",
  "description": "Extract lead details from IndiaMART Lead Manager and export to Google Sheets.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://seller.indiamart.com/*",
    "https://script.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://seller.indiamart.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
